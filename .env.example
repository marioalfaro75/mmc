# ============================================================
# MARS MEDIA CENTRE — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# ============================================================

# --- General Settings ---
# Timezone (IANA format)
TZ=Australia/Sydney
# User ID for file ownership (run `id` to find yours)
PUID=1000
# Group ID for file ownership
PGID=1000
# File permission mask
UMASK=002

# --- Security ---
# Optional: Set an API key to require authentication for the web UI
# Leave blank to disable authentication (localhost-only access is still enforced)
MMC_API_KEY=
# Password for the Gluetun VPN control API (basic auth)
GLUETUN_CONTROL_PASSWORD=changeme

# --- Paths ---
# Root path for all media and downloads
DATA_ROOT=~/.mmc/data
# Root path for container configs
CONFIG_ROOT=~/.mmc/config
# Where backup.sh stores archives
BACKUP_DIR=~/.mmc/backups
# Auto-set by deploy.sh (absolute path to this repo)
HOST_PROJECT_DIR=

# --- NAS (managed Docker volume) ---
# These are populated by the Migration page when you choose "Managed Volume" mode.
# Do not edit by hand — use the UI so the override file stays in sync.
# NAS_HOST=
# NAS_SHARE=
# NAS_USERNAME=
# NAS_PASSWORD=
# NAS_VERS=3.0

# --- VPN (Gluetun) ---
# See https://github.com/qdm12/gluetun-wiki for providers
VPN_SERVICE_PROVIDER=protonvpn
# wireguard or openvpn
VPN_TYPE=wireguard
# Your WireGuard private key
WIREGUARD_PRIVATE_KEY=
# Your WireGuard address (e.g. 10.2.0.2/32)
WIREGUARD_ADDRESSES=
# Optional: preshared key if provider requires it
WIREGUARD_PRESHARED_KEY=
# WireGuard tunnel MTU (1280 recommended for WSL2/NAT networks)
WIREGUARD_MTU=1280
# VPN server country (e.g. Netherlands, Switzerland)
SERVER_COUNTRIES=
# Enable port forwarding (if provider supports it)
VPN_PORT_FORWARDING=on
# Forwarded port number (if known, otherwise leave blank)
FIREWALL_VPN_INPUT_PORTS=

# --- Network: Docker subnet for inter-container communication ---
# This allows download clients behind VPN to talk to Sonarr/Radarr on local network
DOCKER_SUBNET=172.28.0.0/24
# Your home LAN subnet (auto-detected by deploy.sh)
LOCAL_SUBNET=192.168.1.0/24

# --- Web UI Ports ---
PORT_SONARR=8989
PORT_RADARR=7878
PORT_PROWLARR=9696
PORT_QBITTORRENT=8080
PORT_SABNZBD=8081
PORT_SEERR=5055
PORT_BAZARR=6767
PORT_GLUETUN_CONTROL=8000
# Unified Web UI
PORT_UI=3000

# --- Watchtower ---
# Cron: check for updates daily at 4 AM
WATCHTOWER_SCHEDULE="0 0 4 * * *"
# shoutrrr URL for notifications (optional)
WATCHTOWER_NOTIFICATIONS=
# Examples:
#   Discord: discord://token@webhookid
#   Slack:   slack://hook-url
#   Email:   smtp://user:pass@host:port/?from=x&to=y

# --- Service API Keys ---
# Find these in each service's Settings → General (or equivalent) page.
# Required for the web UI to communicate with each service.
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
QBITTORRENT_PASSWORD=
SABNZBD_API_KEY=
SEERR_API_KEY=
BAZARR_API_KEY=
# Unpackerr keys (auto-populated by Detect API Keys)
UN_SONARR_0_API_KEY=
UN_RADARR_0_API_KEY=

# --- TMDB (The Movie Database) ---
# Free API key from https://www.themoviedb.org/settings/api
# Enables searching for movies and TV shows by actor name
TMDB_API_KEY=

# --- Plex (External Server) ---
# URL of your existing Plex server (used for sidebar link)
PLEX_URL=http://localhost:32400

# --- Usenet (SABnzbd) ---
# Configure usenet servers via SABnzbd web UI after first launch.
# These are just for documentation — SABnzbd stores config in its own volume.

# --- Image Tags (pinned for stability — update manually or set to 'latest') ---
IMAGE_SONARR=lscr.io/linuxserver/sonarr:4.0.14
IMAGE_RADARR=lscr.io/linuxserver/radarr:5.21.1
IMAGE_PROWLARR=lscr.io/linuxserver/prowlarr:1.31.2
IMAGE_QBITTORRENT=lscr.io/linuxserver/qbittorrent:5.0.4
IMAGE_SABNZBD=lscr.io/linuxserver/sabnzbd:4.4.1
IMAGE_SEERR=ghcr.io/seerr-team/seerr:2.3.0
IMAGE_BAZARR=lscr.io/linuxserver/bazarr:1.5.1
IMAGE_GLUETUN=qmcgaw/gluetun:v3.40
IMAGE_RECYCLARR=ghcr.io/recyclarr/recyclarr:7.4.0
IMAGE_UNPACKERR=golift/unpackerr:0.14.5
IMAGE_WATCHTOWER=containrrr/watchtower:1.7.1
