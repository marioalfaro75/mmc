# ============================================================
# MARS MEDIA CENTRE — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# ============================================================

# --- General Settings ---
TZ=Australia/Sydney                     # Timezone (IANA format)
PUID=1000                              # User ID for file ownership (run `id` to find yours)
PGID=1000                              # Group ID for file ownership
UMASK=002                              # File permission mask

# --- Paths ---
DATA_ROOT=~/.mmc/data                   # Root path for all media and downloads
CONFIG_ROOT=~/.mmc/config               # Root path for container configs
BACKUP_DIR=~/.mmc/backups               # Where backup.sh stores archives
HOST_PROJECT_DIR=                       # Auto-set by deploy.sh (absolute path to this repo)

# --- VPN (Gluetun) ---
VPN_SERVICE_PROVIDER=protonvpn          # See https://github.com/qdm12/gluetun-wiki for providers
VPN_TYPE=wireguard                      # wireguard or openvpn
WIREGUARD_PRIVATE_KEY=                  # Your WireGuard private key
WIREGUARD_ADDRESSES=                    # Your WireGuard address (e.g. 10.2.0.2/32)
WIREGUARD_PRESHARED_KEY=               # Optional: preshared key if provider requires it
SERVER_COUNTRIES=                        # VPN server country (e.g. Netherlands, Switzerland)
VPN_PORT_FORWARDING=on                  # Enable port forwarding (if provider supports it)
FIREWALL_VPN_INPUT_PORTS=               # Forwarded port (if known, otherwise leave blank)

# --- Network: Docker subnet for inter-container communication ---
# This allows download clients behind VPN to talk to Sonarr/Radarr on local network
DOCKER_SUBNET=172.28.0.0/24
LOCAL_SUBNET=192.168.1.0/24             # Your home LAN subnet

# --- Web UI Ports ---
PORT_SONARR=8989
PORT_RADARR=7878
PORT_PROWLARR=9696
PORT_QBITTORRENT=8080
PORT_SABNZBD=8081
PORT_PLEX=32400
PORT_SEERR=5055
PORT_BAZARR=6767
PORT_TAUTULLI=8181
PORT_GLUETUN_CONTROL=8000
PORT_UI=3000                            # Unified Web UI

# --- Plex ---
PLEX_CLAIM=                             # Get from https://plex.tv/claim (valid 4 minutes)

# --- Watchtower ---
WATCHTOWER_SCHEDULE="0 0 4 * * *"       # Cron: check for updates daily at 4 AM
WATCHTOWER_NOTIFICATIONS=               # shoutrrr URL for notifications (optional)
# Examples:
#   Discord: discord://token@webhookid
#   Slack:   slack://hook-url
#   Email:   smtp://user:pass@host:port/?from=x&to=y

# --- Usenet (SABnzbd) ---
# Configure usenet servers via SABnzbd web UI after first launch.
# These are just for documentation — SABnzbd stores config in its own volume.

# --- Image Tags (pin versions for stability, or use 'latest') ---
IMAGE_SONARR=lscr.io/linuxserver/sonarr:latest
IMAGE_RADARR=lscr.io/linuxserver/radarr:latest
IMAGE_PROWLARR=lscr.io/linuxserver/prowlarr:latest
IMAGE_QBITTORRENT=lscr.io/linuxserver/qbittorrent:latest
IMAGE_SABNZBD=lscr.io/linuxserver/sabnzbd:latest
IMAGE_PLEX=lscr.io/linuxserver/plex:latest
IMAGE_SEERR=ghcr.io/seerr-team/seerr:latest
IMAGE_BAZARR=lscr.io/linuxserver/bazarr:latest
IMAGE_TAUTULLI=lscr.io/linuxserver/tautulli:latest
IMAGE_GLUETUN=qmcgaw/gluetun:latest
IMAGE_RECYCLARR=ghcr.io/recyclarr/recyclarr:latest
IMAGE_UNPACKERR=golift/unpackerr:latest
IMAGE_WATCHTOWER=containrrr/watchtower:latest
